{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "OSRO Revo plugin.ini Editor",
    "version": "0.1.1"
  },
  "tauri": {
    "allowlist": {
      "dialog": {
        "open": true,
        "save": true
      },
      "window": {
        "close": true,
        "all": false
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.osro.pluginini",
      "icon": ["icons/icon.ico"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "OSRO Revo plugin.ini Editor",
        "width": 900,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "closable": true
      }
    ]
  }
}
